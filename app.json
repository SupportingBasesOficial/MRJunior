{
  "expo": {
    "name": "MR Junior",
    "slug": "mr-junior",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mrjunior.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.mrjunior.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
